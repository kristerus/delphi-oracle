# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL (or any Postgres-compatible URL)
# Local docker-compose: postgresql://delphi:delphi@localhost:5432/delphi_oracle
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# REQUIRED — must be at least 32 characters
BETTER_AUTH_SECRET="your-secret-key-min-32-chars-change-this"

# Base URL of the Next.js app (used for OAuth callbacks and session cookies)
BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth — create at https://github.com/settings/developers
# Optional; app still works without it (email/password auth remains available)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Set to "true" once GitHub OAuth is configured above
NEXT_PUBLIC_GITHUB_OAUTH_ENABLED="false"

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Get a free key at https://resend.com — free tier: 3,000 emails/month
# Without this, password reset emails are logged to console only (dev mode)
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ─── AI Providers ─────────────────────────────────────────────────────────────
# At least one key is required for simulations. Keys are supplied by the user
# in the UI and are not stored server-side; these are for the Python backend.
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# ─── Python Backend ───────────────────────────────────────────────────────────
# URL of the FastAPI backend service
BACKEND_URL="http://localhost:8000"

# Shared secret between Next.js and the FastAPI backend (X-API-Key header)
# Generate with: openssl rand -hex 32
BACKEND_API_KEY="your-backend-api-key-change-this"

# ─── App ──────────────────────────────────────────────────────────────────────
# Public URL used for CORS allow-list and OAuth redirect URIs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to "production" in prod deployments
NODE_ENV="development"

# ─── CI / Build ───────────────────────────────────────────────────────────────
# Set to "true" in CI build steps that should skip runtime env validation
# (e.g. `next build` in GitHub Actions where real secrets aren't available)
# SKIP_ENV_VALIDATION="true"
